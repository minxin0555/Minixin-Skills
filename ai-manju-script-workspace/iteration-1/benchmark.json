        },
        {
          "text": "\u6bcf\u6761\u753b\u9762\u63cf\u8ff0\u91cc\u51fa\u73b0\u7684\u73af\u5883\u9648\u8bbe\u7c7b\u7269\u4ef6\u540d\u8bcd \u2264 4 \u4e2a\uff08\u529e\u516c\u684c / \u663e\u793a\u5668 / \u6d3e\u514b\u7b14 / \u73bb\u7483\u95e8 / \u843d\u5730\u7a97 / \u5927\u7406\u77f3\u5730\u677f / \u603b\u88c1\u6905 / CBD \u5168\u666f \u7b49\u7684\u590d\u8ff0\uff09",
          "passed": true,
