        },
        {
          "text": "\u753b\u9762\u63cf\u8ff0\u91cc\u4e0d\u51fa\u73b0\u5f15\u53f7\u3001\u4e0d\u51fa\u73b0 `\u89d2\u8272\u540d:` \u6216 `\u89d2\u8272\u540d\uff1a`\uff0c\u4e0d\u51fa\u73b0\u4efb\u4f55\u76f4\u63a5\u5bf9\u767d\u6587\u5b57",
          "passed": true,
          "evidence": "\u672c\u8282\u6b63\u6587\u65e0\u5bf9\u767d\uff1b\u6240\u6709\u955c\u5934\u7684\u5bf9\u767d\u5b57\u6bb5\u5747\u4e3a\u300e\u65e0\u300f\uff0c\u753b\u9762\u63cf\u8ff0\u91cc\u65e0\u5f15\u53f7\u3001\u65e0\u89d2\u8272\u540d\u5192\u53f7\u3001\u65e0\u5bf9\u767d\u6587\u5b57\u3002"
        },
        {
          "text": "\u51e1\u753b\u9762\u63cf\u8ff0\u542b\u300e\u4fef\u89c6\u300f\u300e\u659c\u4e0b\u300f\u300e\u5168\u666f\u300f\u300e\u8fdc\u666f\u300f\u300e\u659c\u4e0a\u300f\u4e2d\u4efb\u610f\u8bcd\u4e14\u6d89\u53ca\u6797\u665a\u7684\u955c\u5934\uff0c\u753b\u9762\u63cf\u8ff0\u91cc\u5fc5\u987b\u51fa\u73b0 `\u6797\u665a\uff08\u76d8\u9afb\uff09` \u6216 `\u6797\u665a\uff08\u7c73\u767d\u5bb6\u5c45\u670d\uff09` \u8fd9\u7c7b L2 \u951a\u70b9\u5199\u6cd5\u3002\u53ea\u5199\u300e\u6797\u665a\u300f\u4e0d\u5e26\u62ec\u53f7\u951a\u70b9\u4e0d\u901a\u8fc7",
          "passed": false,
